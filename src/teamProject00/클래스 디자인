# 가게 사정으로 인한 원재료의 품질 및 양 낮추기 (인터페이스 이용)
- 인터페이스 생성
(BadAmericano, BadEspresso, BadMintChoco, BadYogurt) 인터페이스 생성

- 서브클래스에 인터페이스 implements하기
(서브클래스 extends 수퍼클래스 implements 인터페이스)

- 각 인터페이스에 추상 메소드 생성
// 원재료의 품질 및 양 낮추기 위한 추상 메소드 생성
(BadAmericano인터페이스)
void lowQuality(int lowShot, double lowWater);

(BadEspresso인터페이스)
void lowQuality(int lowShot, String lowOrigin);

(BadMintChoco인터페이스)
void lowQuality(int lowChoco, int lowMint);

(BadYogurt인터페이스)
void lowQuality(String lowOrigin, String lowMilk);

- 각 서브클래스에 메소드 오버라이드 생성
// 원재료의 품질 및 양 낮추기 위한 BadAmericano 인터페이스의 추상 메소드의 오버라이드 생성
(Americano서브클래스) 
@Override
public void lowQuality(int lowShot, double lowWater){
	System.out.println("변동 사항 : 샷(" + this.shotCount + " -> " + lowShot +
			"), 물의 양(" + this.waterAmount + " -> " + lowWater + ")\n");
	this.shotCount = lowShot;
	this.waterAmount = lowWater;
}

(Espresso서브클래스)
@Override
public void lowQuality(int lowShot, String lowOrigin){
	System.out.println("변동 사항 : 샷(" + this.shotCount + " -> " + lowShot +
			"), 원두 원산지(" + this.coffeeOrigin + " -> " + lowOrigin + ")\n");
	this.shotCount = lowShot;
	this.coffeeOrigin = lowOrigin;
}

(MintChoco서브클래스)
@Override
public void lowQuality(int lowChoco, int lowMint){
	System.out.println("변동 사항 : 초코칩 양(" + this.chocoAmount + " -> " + lowChoco +
			"), 민트 에센스 양(" + this.mintAmount + " -> " + lowMint + ")\n");
	this.chocoAmount = lowChoco;
	this.mintAmount = lowMint;
}

(Yogurt서브클래스)
@Override
public void lowQuality(String lowOrigin, String lowMilk){
	System.out.println("변동 사항 : 요거트 원산지(" + this.yogurtOrigin + " -> " + lowOrigin +
			"), 우유 품질(" + this.milkQuality + " -> "	 + lowMilk + ")\n");
	this.yogurtOrigin = lowOrigin;
	this.milkQuality = lowMilk;
}

# 변동사항 for 반복문에 추가하여 출력
- (cafaMain클래스)의 향상된 for 반복문 사이에 추가
if(item instanceof Americano){
	((Americano)item).lowQuality(1, 500);
}else if(item instanceof Espresso){
	((Espresso)item).lowQuality(1, "중국");
}else if(item instanceof MintChoco){
	((MintChoco)item).lowQuality(1, 1);
}else if(item instanceof Yogurt){
	((Yogurt)item).lowQuality("중국", "중");
}

